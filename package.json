{
  "name": "hostinginfo.gg",
  "version": "1.0.0",
  "type": "module",
  "imports": {
    "#secrets": "./src/server/lib/secrets.ts"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && node bundle.js",
    "build:vite": "vite build",
    "build:prerender": "vite build && node bundle.js && node scripts/prerender.mjs",
    "bundle": "node bundle.js",
    "preview": "vite preview",
    "lint": "eslint src scripts bundle.js drizzle.config.ts eslint.config.js postcss.config.js tailwind.config.js vite.config.ts",
    "lint:fix": "eslint src scripts bundle.js drizzle.config.ts eslint.config.js postcss.config.js tailwind.config.js vite.config.ts --fix",
    "lint:changed": "bash scripts/lint-changed.sh",
    "lint:report": "bash scripts/lint-report.sh",
    "lint:critical": "eslint --quiet src/server/lib/request-auth.ts src/server/lib/auth.ts src/server/lib/session-store.ts scripts/check-secrets.mjs scripts/validate-drizzle-journal.mjs",
    "type-check": "tsc --noEmit -p tsconfig.ci.json",
    "type-check:full": "tsc --noEmit",
    "type-check:critical": "tsc --noEmit -p tsconfig.ci.json",
    "quality:baseline": "bash scripts/quality-baseline.sh",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "clean": "rm -rf dist node_modules/.vite",
    "reset": "npm run clean && npm install",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "security:scan-secrets": "node scripts/check-secrets.mjs",
    "db:validate": "node scripts/validate-drizzle-journal.mjs",
    "ci:verify": "npm run security:scan-secrets && npm run db:validate && npm run type-check:critical && npm run lint:critical && npm run build",
    "predeploy:verify": "npm run build && npm run audit:prod",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "prepare": "node scripts/prepare-husky.mjs"
  },
