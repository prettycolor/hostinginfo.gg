# ──────────────────────────────────────────────
# HostingInfo.gg — Environment Configuration
# ──────────────────────────────────────────────
# Copy to .env and fill in your values:
#   cp env.example .env

# ─── Application ───────────────────────────────
NODE_ENV=development
PORT=20000
APP_URL=http://localhost:20000
VITE_APP_NAME=HostingInfo.gg
VITE_PUBLIC_URL=http://localhost:20000
VITE_API_URL=http://localhost:20000/api

# ─── Database (REQUIRED) ──────────────────────
# Use docker-compose.local.yml for quick setup:
#   docker compose -f docker-compose.local.yml up -d
DB_HOST=localhost
DB_PORT=3100
DB_USER=hostinginfo
DB_PASS=change-this-local-db-password
DB_NAME=hostinginfo

# ─── Authentication (REQUIRED) ────────────────
JWT_SECRET=change-this-to-a-random-64-char-string

# ─── Email (REQUIRED for verification flows) ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=550
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# ─── OAuth Providers (optional) ───────────────
# Google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Apple
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=

# Microsoft
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# ─── External APIs (optional) ─────────────────
# Google Safe Browsing (malware/phishing detection)
# GOOGLE_SAFE_BROWSING_API_KEY=

# Google PageSpeed Insights (performance tab)
# PAGESPEED_API_KEY=

# ─── Feature Flags ────────────────────────────
VITE_SIGNUP_ENABLED=false
SIGNUP_ENABLED=false
VITE_SHOW_DEV_TOOLS=false
